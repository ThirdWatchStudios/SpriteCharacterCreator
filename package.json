{
  "name": "sprite-character-creator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Sprite compositor toolkit for The Water Cooler — characters, props, and office style",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:update": "vitest run -u"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
